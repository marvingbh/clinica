{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run vercel-build",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/jobs/send-reminders",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/jobs/extend-recurrences",
      "schedule": "0 2 * * 1"
    },
    {
      "path": "/api/jobs/generate-recurring-expenses",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/jobs/mark-overdue-expenses",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/jobs/pending-clinical-notes",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/jobs/expire-booking-requests",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/jobs/cleanup-portal-sessions",
      "schedule": "0 4 * * *"
    }
  ]
}
