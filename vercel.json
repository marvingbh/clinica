{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run vercel-build",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/jobs/send-reminders",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/jobs/extend-recurrences",
      "schedule": "0 2 * * 1"
    },
    {
      "path": "/api/jobs/generate-recurring-expenses",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/jobs/mark-overdue-expenses",
      "schedule": "0 6 * * *"
    }
  ]
}
