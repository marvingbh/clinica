{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run vercel-build",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/jobs/extend-recurrences",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/jobs/run-daily",
      "schedule": "0 3 * * *"
    }
  ]
}
