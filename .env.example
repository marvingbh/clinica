# Force Brazil timezone for consistent date parsing across all environments
TZ=America/Sao_Paulo

# =============================================================================
# ENVIRONMENT VARIABLES - Clinica App
# =============================================================================
# Copy this file to .env and fill in the values
# For Vercel deployment, set these in the Vercel dashboard

# =============================================================================
# DATABASE (Required)
# =============================================================================
# For local development with Docker:
POSTGRES_USER=clinica
POSTGRES_PASSWORD=clinica_dev
POSTGRES_DB=clinica_dev
POSTGRES_PORT=5432
POSTGRES_HOST=localhost

# Database URL for Prisma
# Local: postgresql://clinica:clinica_dev@localhost:5432/clinica_dev
# Vercel Postgres: Will be provided automatically as POSTGRES_PRISMA_URL
DATABASE_URL=postgresql://clinica:clinica_dev@localhost:5432/clinica_dev

# =============================================================================
# NEXT.JS (Required)
# =============================================================================
# Local: http://localhost:3000
# Production: https://your-domain.vercel.app or custom domain
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =============================================================================
# AUTHENTICATION SECRETS (Required — each MUST be ≥32 chars in production)
# =============================================================================
# Generate each with: openssl rand -base64 48
#
# IMPORTANT: never reuse the same secret across these three trust domains.
# A compromise on one surface (e.g. leaked appointment URL header) must not
# compromise the others. `src/lib/env.ts` refuses to boot in production if
# any secret is missing or equals a known dev placeholder.
#
# During the initial rotation window, all three fall back to `AUTH_SECRET`
# so a non-split deploy keeps working. Remove that fallback after each
# environment has its own values set.
NEXTAUTH_SECRET=
SUPERADMIN_JWT_SECRET=
APPOINTMENT_LINK_SECRET=

# Legacy secret accepted during a 24h rotation grace window. Leave blank in
# normal operation. When rotating APPOINTMENT_LINK_SECRET, put the old value
# here for 24h so patient confirm/cancel links signed before rotation still
# verify. Remove after the window closes.
LEGACY_APPOINTMENT_LINK_SECRET=

# Set to `compromise` when rotation is triggered by a suspected leak. Skips
# the LEGACY_APPOINTMENT_LINK_SECRET grace window — legacy-signed links are
# rejected immediately.
ROTATION_REASON=

# Legacy single-secret name. Kept as a fallback during the split rollout.
# Remove from production env after each trust domain has its own secret.
AUTH_SECRET=

# =============================================================================
# VERCEL CRON (Required for production)
# =============================================================================
# Secret to authenticate Vercel Cron jobs
# Generate with: openssl rand -base64 32
CRON_SECRET=

# =============================================================================
# UPSTASH REDIS (Rate limiter — required in production, optional in dev)
# =============================================================================
# Provision a database at https://console.upstash.com/redis and paste the
# REST URL + TOKEN. When unset (local dev without Upstash), rate-limit falls
# back to an in-memory sliding-window that only works within a single process.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
