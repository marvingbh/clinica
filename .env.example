# Force Brazil timezone for consistent date parsing across all environments
TZ=America/Sao_Paulo

# =============================================================================
# ENVIRONMENT VARIABLES - Clinica App
# =============================================================================
# Copy this file to .env and fill in the values
# For Vercel deployment, set these in the Vercel dashboard

# =============================================================================
# DATABASE (Required)
# =============================================================================
# For local development with Docker:
POSTGRES_USER=clinica
POSTGRES_PASSWORD=clinica_dev
POSTGRES_DB=clinica_dev
POSTGRES_PORT=5432
POSTGRES_HOST=localhost

# Database URL for Prisma
# Local: postgresql://clinica:clinica_dev@localhost:5432/clinica_dev
# Vercel Postgres: Will be provided automatically as POSTGRES_PRISMA_URL
DATABASE_URL=postgresql://clinica:clinica_dev@localhost:5432/clinica_dev

# =============================================================================
# NEXT.JS (Required)
# =============================================================================
# Local: http://localhost:3000
# Production: https://your-domain.vercel.app or custom domain
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =============================================================================
# AUTHENTICATION (Required)
# =============================================================================
# NextAuth.js secret - Generate with: npx auth secret
# IMPORTANT: Use a strong, unique value in production
AUTH_SECRET=my-super-secret-key-for-development-only-change-in-production

# =============================================================================
# VERCEL CRON (Required for production)
# =============================================================================
# Secret to authenticate Vercel Cron jobs
# Generate with: openssl rand -base64 32
CRON_SECRET=

# =============================================================================
# AI ASSISTANT (Optional — feature "ai-evolucao")
# =============================================================================
# Anthropic API key. Also used by the expense-matcher AI classifier.
# When unset, the AI provider falls back to a deterministic local mock and the
# "Gerar com IA" panel reports the assistant as unavailable at runtime.
ANTHROPIC_API_KEY=
# Provider selection: "anthropic" | "mock". Defaults to anthropic when a key is
# present, otherwise mock (used in dev and tests).
AI_PROVIDER=
# Model id for the Anthropic provider. Defaults to claude-opus-4-8.
# claude-sonnet-4-6 is a cheaper alternative.
AI_MODEL=

# =============================================================================
# TELECONSULTA / TELEHEALTH (Optional — feature "teleconsulta")
# =============================================================================
# Video provider: "jitsi" (default in non-test) | "mock" (default under test).
TELEHEALTH_PROVIDER=
# Jitsi domain for the built-in room, e.g. "meet.suaclinica.com.br" or
# "8x8.vc/<tenant>". REQUIRED for the jitsi provider to be "configured" — when
# unset, the per-clinic teleconsulta toggle is disabled with a support notice
# and {{videoLink}} is never injected into notifications.
# Room names are HMAC-derived from AUTH_SECRET; patient links use NEXT_PUBLIC_APP_URL.
TELEHEALTH_JITSI_DOMAIN=
